def heuristic(city):
    return hx[cities.index(city)]


def neighbors(city):
    i = cities.index(city)
    result = []
    for j in range(n):
        if adj[i][j] > 0:
            result.append(cities[j])
    return result


def GreedyBestFirst(start, goal):
    frontier = PriorityQueue()
    frontier.put(start, heuristic(start))
    reached = set()

    step = 0

    while not frontier.is_empty():
        city = frontier.get()

        if city in reached:
            continue

        reached.add(city)
        step += 1

        print(step, city, heuristic(city))

        if city == goal:
            print("Goal reached")
            return

        for nb in neighbors(city):
            if nb not in reached:
                frontier.put(nb, heuristic(nb))


def Astar(start, goal):
    frontier = PriorityQueue()
    frontier.put(start, heuristic(start))

    came_from = {}
    cost_so_far = {start: 0}

    step = 0

    while not frontier.is_empty():
        city = frontier.get()

        if city == goal:
            path = [city]
            while city in came_from:
                city = came_from[city]
                path.append(city)
            path.reverse()
            print(path)
            print(cost_so_far[goal])
            return

        step += 1

        for nb in neighbors(city):
            new_cost = cost_so_far[city] + adj[cities.index(city)][cities.index(nb)]

            if nb not in cost_so_far or new_cost < cost_so_far[nb]:
                cost_so_far[nb] = new_cost
                came_from[nb] = city
                frontier.put(nb, new_cost + heuristic(nb))


